// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String?
  servings    Int?
  prepTime    Int? // minutes
  cookTime    Int? // minutes
  steps       Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Ingrédients de la recette (many-to-many via jonction explicite RecipeIngredient,
  // qui porte la quantité et l'unité).
  recipeIngredients RecipeIngredient[]
  // Ustensiles de la recette (many-to-many via jonction explicite RecipeUtensil,
  // qui porte la quantité).
  recipeUtensils    RecipeUtensil[]
  // Tags partagés (many-to-many via table de jonction explicite RecipeTag).
  recipeTags        RecipeTag[]
}

// Catalogue d'ingrédients réutilisables (ex. "farine", "œuf"). name unique.
model Ingredient {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}

// Catalogue d'unités de mesure réutilisables (ex. "g", "kg", "ml", "pincée", "unité").
model Unit {
  id                String             @id @default(cuid())
  name              String             @unique
  recipeIngredients RecipeIngredient[]
}

// Jonction explicite Recipe <-> Ingredient, porteuse de la quantité et de l'unité.
// Table "RecipeIngredient" (colonnes recipeId / ingredientId, PK composite).
model RecipeIngredient {
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  ingredientId String
  quantity     Float? // ex. 250, 0.5, 3 — optionnel ("sel à volonté")
  unit         Unit?      @relation(fields: [unitId], references: [id], onDelete: SetNull)
  unitId       String?
  position     Int        @default(0) // ordre d'affichage dans la recette

  @@id([recipeId, ingredientId])
  @@index([ingredientId])
  @@index([unitId])
}

// Catalogue d'ustensiles réutilisables (ex. "cuillère en bois", "moule à manqué
// 24 cm", "poêle 28 cm"). name unique. Les déclinaisons par taille (diamètre) sont
// des entrées distinctes du catalogue.
model Utensil {
  id             String          @id @default(cuid())
  name           String          @unique
  recipeUtensils RecipeUtensil[]
}

// Jonction explicite Recipe <-> Utensil, porteuse de la quantité (nombre d'ustensiles).
// Table "RecipeUtensil" (colonnes recipeId / utensilId, PK composite).
model RecipeUtensil {
  recipe    Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId  String
  utensil   Utensil @relation(fields: [utensilId], references: [id], onDelete: Cascade)
  utensilId String
  quantity  Int? // ex. 1, 2 — optionnel (1 par défaut à l'affichage)
  position  Int     @default(0) // ordre d'affichage dans la recette

  @@id([recipeId, utensilId])
  @@index([utensilId])
}

// Un tag est réutilisable et partagé entre plusieurs recettes.
model Tag {
  id         String      @id @default(cuid())
  name       String      @unique
  recipeTags RecipeTag[]
}

// Table de jonction explicite de la relation many-to-many Recipe <-> Tag.
// Table : "RecipeTag", colonnes : "recipeId" et "tagId" (clé primaire composite).
model RecipeTag {
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId    String

  @@id([recipeId, tagId])
  @@index([tagId])
}
